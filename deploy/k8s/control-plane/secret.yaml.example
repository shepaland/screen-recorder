apiVersion: v1
kind: Secret
metadata:
  name: control-plane-secret
  labels:
    app: control-plane
type: Opaque
data:
  # base64-encoded values — REPLACE with real values before deploying
  # echo -n 'your-value' | base64
  DB_USERNAME: CHANGE_ME_BASE64
  DB_PASSWORD: CHANGE_ME_BASE64
  INTERNAL_API_KEY: CHANGE_ME_BASE64
