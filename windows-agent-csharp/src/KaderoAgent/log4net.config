<?xml version="1.0" encoding="utf-8" ?>
<log4net>
  <!-- Rolling file appender with rotation by size.
       MinimalLock allows both Service and Tray processes to write to the same file. -->
  <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
    <file type="log4net.Util.PatternString" value="%property{LogPath}/kadero-agent.log" />
    <appendToFile value="true" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyyMMdd" />
    <maxSizeRollBackups value="10" />
    <maximumFileSize value="10MB" />
    <staticLogFileName value="true" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level %logger - %message%newline" />
    </layout>
  </appender>

  <!-- HTTP traffic appender — dedicated log for server communication -->
  <appender name="HttpTrafficAppender" type="log4net.Appender.RollingFileAppender">
    <file type="log4net.Util.PatternString" value="%property{LogPath}/kadero-http.log" />
    <appendToFile value="true" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyyMMdd" />
    <maxSizeRollBackups value="5" />
    <maximumFileSize value="10MB" />
    <staticLogFileName value="true" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level %logger - %message%newline" />
    </layout>
  </appender>

  <!-- Pipe IPC appender -->
  <appender name="PipeTrafficAppender" type="log4net.Appender.RollingFileAppender">
    <file type="log4net.Util.PatternString" value="%property{LogPath}/kadero-pipe.log" />
    <appendToFile value="true" />
    <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyyMMdd" />
    <maxSizeRollBackups value="3" />
    <maximumFileSize value="5MB" />
    <staticLogFileName value="true" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%thread] %-5level - %message%newline" />
    </layout>
  </appender>

  <!-- Route HTTP traffic to dedicated log -->
  <logger name="KaderoAgent.Util.ApiClient" additivity="true">
    <level value="DEBUG" />
    <appender-ref ref="HttpTrafficAppender" />
  </logger>

  <!-- Route HeartbeatService to HTTP log too -->
  <logger name="KaderoAgent.Command.HeartbeatService" additivity="true">
    <level value="DEBUG" />
    <appender-ref ref="HttpTrafficAppender" />
  </logger>

  <!-- Route pipe traffic to dedicated log -->
  <logger name="KaderoAgent.Ipc.PipeServer" additivity="true">
    <level value="DEBUG" />
    <appender-ref ref="PipeTrafficAppender" />
  </logger>

  <logger name="KaderoAgent.Ipc.PipeClient" additivity="true">
    <level value="DEBUG" />
    <appender-ref ref="PipeTrafficAppender" />
  </logger>

  <!-- Route TrayWindowTracker and BrowserUrlExtractor to main log at INFO level -->
  <logger name="KaderoAgent.Tray.TrayWindowTracker" additivity="true">
    <level value="INFO" />
  </logger>

  <logger name="KaderoAgent.Audit.BrowserUrlExtractor" additivity="true">
    <level value="INFO" />
  </logger>

  <root>
    <level value="INFO" />
    <appender-ref ref="RollingFileAppender" />
  </root>
</log4net>
